<svg viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Gradients for visual appeal -->
    <linearGradient id="headerGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#2563eb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:1" />
    </linearGradient>
    
    <linearGradient id="cachingGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:0.2" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:0.3" />
    </linearGradient>
    
    <linearGradient id="featureGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:0.2" />
      <stop offset="100%" style="stop-color:#d97706;stop-opacity:0.3" />
    </linearGradient>
    
    <linearGradient id="depGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ef4444;stop-opacity:0.2" />
      <stop offset="100%" style="stop-color:#dc2626;stop-opacity:0.3" />
    </linearGradient>
    
    <!-- Arrow marker -->
    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#374151" />
    </marker>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#f8fafc"/>
  
  <!-- Title -->
  <rect x="50" y="20" width="700" height="50" rx="8" fill="url(#headerGrad)"/>
  <text x="400" y="48" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="18" font-weight="bold">
    Intelligent ML Experiment Optimization Framework
  </text>
  
  <!-- Three-Phase Pipeline Header -->
  <rect x="80" y="90" width="640" height="30" rx="5" fill="#e5e7eb" stroke="#9ca3af"/>
  <text x="400" y="108" text-anchor="middle" fill="#374151" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    Three-Phase ML Pipeline
  </text>
  
  <!-- Phase boxes -->
  <rect x="90" y="130" width="190" height="40" rx="5" fill="#ddd6fe" stroke="#8b5cf6"/>
  <text x="185" y="152" text-anchor="middle" fill="#5b21b6" font-family="Arial, sans-serif" font-size="12" font-weight="bold">
    Phase 1: Model Selection
  </text>
  
  <rect x="305" y="130" width="190" height="40" rx="5" fill="#ddd6fe" stroke="#8b5cf6"/>
  <text x="400" y="152" text-anchor="middle" fill="#5b21b6" font-family="Arial, sans-serif" font-size="12" font-weight="bold">
    Phase 2: Hyperparameter Opt.
  </text>
  
  <rect x="520" y="130" width="190" height="40" rx="5" fill="#ddd6fe" stroke="#8b5cf6"/>
  <text x="615" y="152" text-anchor="middle" fill="#5b21b6" font-family="Arial, sans-serif" font-size="12" font-weight="bold">
    Phase 3: Final Training
  </text>
  
  <!-- Arrows between phases -->
  <line x1="285" y1="150" x2="300" y2="150" stroke="#374151" stroke-width="2" marker-end="url(#arrowhead)"/>
  <line x1="500" y1="150" x2="515" y2="150" stroke="#374151" stroke-width="2" marker-end="url(#arrowhead)"/>
  
  <!-- Main Framework Components -->
  
  <!-- Intelligent Caching Component -->
  <rect x="50" y="200" width="220" height="160" rx="8" fill="url(#cachingGrad)" stroke="#10b981" stroke-width="2"/>
  <text x="160" y="220" text-anchor="middle" fill="#047857" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    Intelligent Caching Framework
  </text>
  
  <!-- Caching sub-components -->
  <rect x="60" y="235" width="200" height="25" rx="3" fill="#ecfdf5" stroke="#10b981"/>
  <text x="160" y="250" text-anchor="middle" fill="#047857" font-family="Arial, sans-serif" font-size="10">
    Self-Learning Cache Prediction
  </text>
  
  <rect x="60" y="265" width="200" height="25" rx="3" fill="#ecfdf5" stroke="#10b981"/>
  <text x="160" y="280" text-anchor="middle" fill="#047857" font-family="Arial, sans-serif" font-size="10">
    Configuration Fingerprinting
  </text>
  
  <rect x="60" y="295" width="200" height="25" rx="3" fill="#ecfdf5" stroke="#10b981"/>
  <text x="160" y="310" text-anchor="middle" fill="#047857" font-family="Arial, sans-serif" font-size="10">
    Automatic Cache Invalidation
  </text>
  
  <rect x="60" y="325" width="200" height="25" rx="3" fill="#ecfdf5" stroke="#10b981"/>
  <text x="160" y="340" text-anchor="middle" fill="#047857" font-family="Arial, sans-serif" font-size="10">
    LSTM/CatBoost Predictors
  </text>
  
  <!-- Feature Engineering Component -->
  <rect x="290" y="200" width="220" height="160" rx="8" fill="url(#featureGrad)" stroke="#f59e0b" stroke-width="2"/>
  <text x="400" y="220" text-anchor="middle" fill="#d97706" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    105-Feature Engineering
  </text>
  
  <!-- Feature sub-components -->
  <rect x="300" y="235" width="200" height="25" rx="3" fill="#fefce8" stroke="#f59e0b"/>
  <text x="400" y="250" text-anchor="middle" fill="#d97706" font-family="Arial, sans-serif" font-size="10">
    Time-Domain Features (EEG/EOG/EMG)
  </text>
  
  <rect x="300" y="265" width="200" height="25" rx="3" fill="#fefce8" stroke="#f59e0b"/>
  <text x="400" y="280" text-anchor="middle" fill="#d97706" font-family="Arial, sans-serif" font-size="10">
    Frequency-Domain (PSD Bands)
  </text>
  
  <rect x="300" y="295" width="200" height="25" rx="3" fill="#fefce8" stroke="#f59e0b"/>
  <text x="400" y="310" text-anchor="middle" fill="#d97706" font-family="Arial, sans-serif" font-size="10">
    Time-Frequency (Wavelet Coeffs)
  </text>
  
  <rect x="300" y="325" width="200" height="25" rx="3" fill="#fefce8" stroke="#f59e0b"/>
  <text x="400" y="340" text-anchor="middle" fill="#d97706" font-family="Arial, sans-serif" font-size="10">
    Cross-Subject Generalization
  </text>
  
  <!-- Dependency Tracking Component -->
  <rect x="530" y="200" width="220" height="160" rx="8" fill="url(#depGrad)" stroke="#ef4444" stroke-width="2"/>
  <text x="640" y="220" text-anchor="middle" fill="#dc2626" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    Dependency Tracking
  </text>
  
  <!-- Dependency sub-components -->
  <rect x="540" y="235" width="200" height="25" rx="3" fill="#fef2f2" stroke="#ef4444"/>
  <text x="640" y="250" text-anchor="middle" fill="#dc2626" font-family="Arial, sans-serif" font-size="10">
    Fine-Grained Version Control
  </text>
  
  <rect x="540" y="265" width="200" height="25" rx="3" fill="#fef2f2" stroke="#ef4444"/>
  <text x="640" y="280" text-anchor="middle" fill="#dc2626" font-family="Arial, sans-serif" font-size="10">
    Environment State Tracking
  </text>
  
  <rect x="540" y="295" width="200" height="25" rx="3" fill="#fef2f2" stroke="#ef4444"/>
  <text x="640" y="310" text-anchor="middle" fill="#dc2626" font-family="Arial, sans-serif" font-size="10">
    Reproducibility Verification
  </text>
  
  <rect x="540" y="325" width="200" height="25" rx="3" fill="#fef2f2" stroke="#ef4444"/>
  <text x="640" y="340" text-anchor="middle" fill="#dc2626" font-family="Arial, sans-serif" font-size="10">
    Seamless Experiment Resumption
  </text>
  
  <!-- Integration arrows -->
  <line x1="160" y1="370" x2="400" y2="390" stroke="#6b7280" stroke-width="2" marker-end="url(#arrowhead)" stroke-dasharray="5,5"/>
  <line x1="400" y1="370" x2="400" y2="390" stroke="#6b7280" stroke-width="2" marker-end="url(#arrowhead)"/>
  <line x1="640" y1="370" x2="400" y2="390" stroke="#6b7280" stroke-width="2" marker-end="url(#arrowhead)" stroke-dasharray="5,5"/>
  
  <!-- Central Integration Hub -->
  <rect x="300" y="390" width="200" height="80" rx="8" fill="#f3f4f6" stroke="#374151" stroke-width="2"/>
  <text x="400" y="415" text-anchor="middle" fill="#374151" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    Integrated Framework
  </text>
  <text x="400" y="435" text-anchor="middle" fill="#374151" font-family="Arial, sans-serif" font-size="11">
    Configuration Fingerprints
  </text>
  <text x="400" y="450" text-anchor="middle" fill="#374151" font-family="Arial, sans-serif" font-size="11">
    Content-Addressable Storage
  </text>
  <text x="400" y="465" text-anchor="middle" fill="#374151" font-family="Arial, sans-serif" font-size="11">
    Scientific Rigor Validation
  </text>
  
  <!-- Output Benefits -->
  <rect x="150" y="490" width="500" height="80" rx="8" fill="#ede9fe" stroke="#7c3aed" stroke-width="2"/>
  <text x="400" y="510" text-anchor="middle" fill="#6b21a8" font-family="Arial, sans-serif" font-size="14" font-weight="bold">
    Expected Outcomes
  </text>
  
  <!-- Benefits list -->
  <text x="170" y="530" fill="#6b21a8" font-family="Arial, sans-serif" font-size="11">
    • Reduced computational costs through intelligent caching
  </text>
  <text x="170" y="545" fill="#6b21a8" font-family="Arial, sans-serif" font-size="11">
    • Enhanced cross-subject generalization via 105-feature approach
  </text>
  <text x="170" y="560" fill="#6b21a8" font-family="Arial, sans-serif" font-size="11">
    • Improved reproducibility and seamless experiment resumption
  </text>
  
  <!-- Arrow from integration to outcomes -->
  <line x1="400" y1="475" x2="400" y2="485" stroke="#374151" stroke-width="2" marker-end="url(#arrowhead)"/>
  
</svg>