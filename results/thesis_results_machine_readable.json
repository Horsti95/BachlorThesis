  "key_thesis_claims": {
    "claim_1_cache_speedup": {
      "claim": "Fingerprint-based model caching provides significant speedup for LOSO cross-validation",
      "evidence": "XGBoost: 122-498x speedup across 9 configs. Best case 498x (61 min cold → 7.4s warm).",
      "validated": true
    },
    "claim_2_accuracy_preservation": {
      "claim": "Cached models produce identical predictions to freshly trained models",
      "evidence": "accuracy_match=True for all 18 configs (9 XGB + 9 RF). warm_accuracy == cold_accuracy in every case.",
      "validated": true
    },
    "claim_3_anova_efficiency": {
      "claim": "ANOVA feature selection is vastly faster than Mutual Information with comparable or better accuracy",
      "evidence": "174x faster, 3.68% MORE accurate (84.3% vs 80.6%)",
      "validated": true
    },
    "claim_4_scalability": {
      "claim": "Cache benefits scale with dataset size",
      "evidence": "SVM-linear: 1736x (10 subj) → 3093x (128 subj). SVM-RBF: 9x → 201x. More subjects = higher speedup.",
      "validated": true
    },
    "claim_5_model_viability_spectrum": {
      "claim": "Not all models benefit equally from caching",
      "evidence": "Gradient Boosting: 18030x (tiny cache). RF: 12-110x (20 GB cache). Extra Trees: 4x (NOT VIABLE). Clear viability spectrum.",
      "validated": true
    },
    "claim_6_hardware_portability": {
      "claim": "Cache viability results are consistent across different hardware",
      "evidence": "Old machine results match new machine viability verdicts for all tested models.",
      "validated": true
    }
  }
}
